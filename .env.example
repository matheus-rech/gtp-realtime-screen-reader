# Root environment variables (for docker-compose)

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Backend Configuration
REDIS_URL=redis://redis:6379
FRAME_RATE_LIMIT=2
MAX_SESSIONS=100
VISUAL_MAX_RESOLUTION=1024

# Frontend Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# For production deployment, adjust NEXT_PUBLIC_BACKEND_URL to your backend URL
# Examples:
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.herokuapp.com
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com